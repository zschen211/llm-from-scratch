# 使用国内可用的 Docker Hub 镜像代理（Daocloud），避免直连 docker.io
#
# Rust 扩展 bpe_core 由 build.sh 在宿主机预编译为 wheel，构建时直接注入，
# 容器内无需 Rust 工具链。运行时 `import bpe_core` 可用（_rust_bridge 走 Rust）。

FROM docker.m.daocloud.io/library/python:3.12-slim

WORKDIR /workspace

# 三方依赖：由宿主机 ./docker/build.sh 阶段 0 预下载 wheel，构建时离线安装（容器内无需访问 PyPI）。
# 若未先下载，docker build 会因缺少文件失败。
COPY docker/requirements-thirdparty.txt /tmp/requirements-thirdparty.txt
COPY docker/wheels/thirdparty /tmp/wheels

# 先复制依赖元数据（与 uv.lock 对齐；wheel 目录已含解析后的版本）。
COPY pyproject.toml uv.lock /workspace/

# 勿使用 pip install -U pip（会访问 PyPI）；基础镜像已含 pip，仅 --no-index + find-links
RUN pip install --no-index --find-links=/tmp/wheels -r /tmp/requirements-thirdparty.txt

# 安装 Rust 扩展 bpe_core（wheel 须保留 PEP 427 文件名，勿用固定名 bpe_core.whl）
COPY docker/wheels/bpe_core-*.whl /tmp/
RUN pip install --no-cache-dir /tmp/bpe_core-*.whl && rm -f /tmp/bpe_core-*.whl

# 再复制项目代码（data/ 会通过 .dockerignore 排除，并在运行时以 volume 方式挂载）
COPY src /workspace/src
COPY cli /workspace/cli
COPY main.py /workspace/

# 离线可编辑安装：隔离构建会拉 PyPI，故先装 setuptools/wheel 再 --no-build-isolation
RUN pip install --no-index --find-links=/tmp/wheels setuptools wheel && \
    pip install --no-deps --no-build-isolation --no-index --find-links=/tmp/wheels -e .

ENV PYTHONPATH=/workspace/src

# 默认入口：sandbox runner 的容器侧执行器
ENTRYPOINT ["python", "-m", "llm_from_scratch.sandbox.sandbox_runner_entrypoint"]
