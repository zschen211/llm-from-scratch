# 使用国内可用的 Docker Hub 镜像代理（Daocloud），避免直连 docker.io
FROM docker.m.daocloud.io/library/python:3.12-slim

WORKDIR /workspace

# 使用项目一致的 PyPI 镜像源，避免容器内 DNS/直连 PyPI 不稳定导致 build 失败。
ENV PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
ENV PIP_DISABLE_PIP_VERSION_CHECK=1
ENV PIP_CACHE_DIR=/root/.cache/pip

# linux-perf 体积大、依赖多，首次 apt 安装会较慢；重建镜像时 BuildKit 会复用 apt 缓存层。
# 不需要 perf 时：`docker build --build-arg INSTALL_PERF=0 ...` 可跳过该层以显著加快构建。
ARG INSTALL_PERF=1
# 可选：国内 Debian 镜像，加速 apt 下载（与 python:3.12-slim 的 bookworm 源对应）
ARG DEBIAN_MIRROR=https://mirrors.tuna.tsinghua.edu.cn/debian

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt/lists,sharing=locked \
    set -eux; \
    if [ "$INSTALL_PERF" = "1" ]; then \
      if [ -n "$DEBIAN_MIRROR" ]; then \
        SEC_MIRROR="${DEBIAN_MIRROR%/debian}/debian-security"; \
        for f in /etc/apt/sources.list.d/debian.sources /etc/apt/sources.list; do \
          if [ -f "$f" ]; then \
            sed -i "s|http://deb.debian.org/debian|$DEBIAN_MIRROR|g" "$f"; \
            sed -i "s|https://deb.debian.org/debian|$DEBIAN_MIRROR|g" "$f"; \
            sed -i "s|http://security.debian.org/debian-security|$SEC_MIRROR|g" "$f"; \
            sed -i "s|https://security.debian.org/debian-security|$SEC_MIRROR|g" "$f"; \
          fi; \
        done; \
      fi; \
      apt-get update; \
      apt-get install -y --no-install-recommends linux-perf; \
      rm -rf /var/lib/apt/lists/*; \
    fi

# 先复制依赖元数据，构建稳定的“三方依赖层”缓存（源码变化不应触发重装）。
COPY pyproject.toml uv.lock /workspace/

# 安装构建工具 + 三方依赖（仅来自 pyproject 的 project.dependencies）
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install -U pip setuptools wheel && \
    python -c "import tomllib; from pathlib import Path; data=tomllib.loads(Path('/workspace/pyproject.toml').read_text(encoding='utf-8')); deps=data.get('project', {}).get('dependencies', []); Path('/tmp/requirements-thirdparty.txt').write_text('\\n'.join(deps) + '\\n', encoding='utf-8')" && \
    pip install -r /tmp/requirements-thirdparty.txt

# 再复制项目代码（data/ 会通过 .dockerignore 排除，并在运行时以 volume 方式挂载）
COPY src /workspace/src
COPY cli /workspace/cli
COPY main.py /workspace/

# 安装本地项目本身，不重复安装三方依赖
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install --no-deps -e .

ENV PYTHONPATH=/workspace/src

# 默认入口：sandbox runner 的容器侧执行器
ENTRYPOINT ["python", "-m", "llm_from_scratch.sandbox.sandbox_runner_entrypoint"]

